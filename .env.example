# --- Flask Core ---
SECRET_KEY=your_secret_key_here
FLASK_APP=backend.app
FLASK_ENV=production
BASE_URL=https://your-app-name.render.com

# --- Database ---
# SQLite example: sqlite:///database/app.db
# PostgreSQL example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///database/app.db

# --- Authentication & Third Party ---
DEFAULT_STAFF_PASSWORD=change_me_to_something_secure

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Google Calendar
GOOGLE_CLIENT_ID=your_google_id
GOOGLE_CLIENT_SECRET=your_google_secret

# Twilio (WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Mail (SendGrid)
SENDGRID_API_KEY=your_sendgrid_key
MAIL_DEFAULT_SENDER=notifications@yourdomain.com

# --- Firebase (Frontend/Backend Sync) ---
# Paste your Firebase Client Config here
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
